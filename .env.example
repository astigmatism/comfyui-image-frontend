# Application identity and listener
CIF_APP_TITLE=Home Image Studio
CIF_LISTEN_HOST=0.0.0.0
CIF_LISTEN_PORT=8000
CIF_LOG_LEVEL=INFO

# Persistent application-owned data. The Compose example mounts its named
# volume `comfyui-image-frontend-data` here.
CIF_DATA_DIR=/data
CIF_DATABASE_PATH=/data/app.db

# REQUIRED: generate a unique value, for example:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
CIF_SESSION_SECRET=replace-with-at-least-32-random-characters
CIF_SESSION_COOKIE_NAME=cif_session
CIF_SESSION_TTL_HOURS=168
# Set true when the browser reaches this app only over HTTPS.
CIF_COOKIE_SECURE=false
CIF_COOKIE_SAMESITE=lax

# Used only when the database has no users. These values never reset an
# existing account. The temporary password must have at least 12 characters.
CIF_BOOTSTRAP_ADMIN_USERNAME=admin
CIF_BOOTSTRAP_ADMIN_TEMPORARY_PASSWORD=replace-with-a-long-temporary-password

# External ComfyUI. These host URLs work with compose.example.yml when the
# services run directly on the Docker host. Use Docker service names instead
# when they share a network, e.g. http://comfyui:8188.
CIF_COMFYUI_BASE_URL=http://host.docker.internal:8188
# Omit to derive ws://.../ws from the HTTP URL.
# CIF_COMFYUI_WS_URL=ws://host.docker.internal:8188/ws
CIF_COMFYUI_WORKFLOW_DIRECTORY=workflows/front-end
CIF_COMFYUI_CONCURRENCY=1
CIF_EXTERNAL_HEALTH_INTERVAL_SECONDS=10
CIF_DISPATCH_POLL_SECONDS=0.4
CIF_RECONCILIATION_GRACE_SECONDS=5

# Optional Ollama. Leave blank or remove to disable Prompt Assistant only.
CIF_OLLAMA_BASE_URL=http://host.docker.internal:11434
CIF_PROMPT_TEMPLATE_VERSION=v1

# Upload and derivative limits
CIF_UPLOAD_MAX_BYTES=20971520
CIF_UPLOAD_MAX_PIXELS=50000000
CIF_THUMBNAIL_MAX_EDGE=640

# Basic login backoff
CIF_LOGIN_MAX_ATTEMPTS=6
CIF_LOGIN_WINDOW_SECONDS=300
CIF_LOGIN_BLOCK_SECONDS=300

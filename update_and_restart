#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
cd "$SCRIPT_DIR"

COMPOSE_FILE=${CIF_COMPOSE_FILE:-compose.example.yml}
SERVICE=${CIF_COMPOSE_SERVICE:-comfyui-image-frontend}
STOP_TIMEOUT=${CIF_UPDATE_STOP_TIMEOUT:-60}
START_TIMEOUT=${CIF_UPDATE_START_TIMEOUT:-120}

die() {
  echo "update_and_restart: $*" >&2
  exit 1
}

command -v git >/dev/null 2>&1 || die "git is required."
command -v docker >/dev/null 2>&1 || die "Docker is required."
docker compose version >/dev/null 2>&1 || die "Docker Compose is required."

[[ -f "$COMPOSE_FILE" ]] || die "Compose file not found: $COMPOSE_FILE"
[[ "$STOP_TIMEOUT" =~ ^[1-9][0-9]*$ ]] || die "CIF_UPDATE_STOP_TIMEOUT must be a positive integer."
[[ "$START_TIMEOUT" =~ ^[1-9][0-9]*$ ]] || die "CIF_UPDATE_START_TIMEOUT must be a positive integer."
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Run this script from a Git checkout."

BRANCH=$(git branch --show-current)
[[ -n "$BRANCH" ]] || die "Refusing to update a detached HEAD."
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null) ||
  die "Branch '$BRANCH' has no upstream branch."

if [[ -n $(git status --porcelain --untracked-files=normal) ]]; then
  die "The working tree is not clean. Commit, stash, or remove local changes before updating."
fi

compose=(docker compose -f "$COMPOSE_FILE")
"${compose[@]}" config --quiet

container_may_be_stopped=0
recover_on_failure() {
  local status=$?
  trap - EXIT
  if ((status != 0 && container_may_be_stopped)); then
    echo "Update failed; attempting to restart the last available image." >&2
    if ! "${compose[@]}" up -d --no-build "$SERVICE"; then
      echo "Automatic restart failed. Run: docker compose -f $COMPOSE_FILE up -d $SERVICE" >&2
    fi
  fi
  exit "$status"
}
trap recover_on_failure EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

echo "Stopping $SERVICE gracefully..."
container_may_be_stopped=1
"${compose[@]}" stop --timeout "$STOP_TIMEOUT" "$SERVICE"

echo "Updating $BRANCH from $UPSTREAM..."
git pull --ff-only

# Validate the newly pulled Compose definition before asking Docker to build it.
"${compose[@]}" config --quiet

echo "Building and starting $SERVICE..."
"${compose[@]}" up -d --build --wait --wait-timeout "$START_TIMEOUT" "$SERVICE"

container_may_be_stopped=0
trap - EXIT INT TERM
echo "$SERVICE is updated and healthy."
